{
  "name": "dianzi-junshi-app",
  "version": "5.0.0",
  "private": true,
  "description": "电子军师桌面后端：SQLite 时间画像、批量截图和本机 AI 连接",
  "type": "module",
  "scripts": {
    "start": "bun run server.ts --open",
    "dev": "bun --watch run server.ts",
    "build:app": "bun build --compile server.ts --outfile dist/dianzi-junshi-app",
    "check": "tsc --noEmit && bun build server.ts --target bun --outdir /tmp/dj-typecheck-out",
    "test": "bun test",
    "evaluate": "bun run evaluate.ts",
    "verify": "bun run check && bun test && bun run evaluate"
  },
  "dependencies": {
    "sqlite-vec": "0.1.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
